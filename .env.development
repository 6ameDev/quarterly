COLLECTION_NAME="transcripts"
PERSIST_DIR="./chroma_db"
EMBED_MODEL_NAME="nomic-embed-text:latest"
LLM_MODEL_NAME="qwen2.5:1.5b"
BASE_URL="http://localhost:11434"
SYSTEM_PROMPT="You are an expert financial and technical analyst.\nUse the provided context to accurately answer the user's question.\nIf the provided context does not contain information about the specific entity (e.g., the specific company) mentioned in the question, state clearly that you do not have information for that entity. Do not use information about one company to answer questions about another.'\nAlways be precise and objective."
